<Window x:Class="PL.CourierLogin.CourierMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.CourierLogin"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        xmlns:Items="clr-namespace:PL.Helpers.Items"
        mc:Ignorable="d"
        Title="Courier Workspace" Height="1080" Width="1920"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Style="{StaticResource CyberWindowTheme}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Color_Control}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource Color_Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.03" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Color_TextMain}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="15,8" CornerRadius="8" x:Name="border">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2 L12,12 M7,5 A8,8 0 1,0 17,5" Stroke="{TemplateBinding Foreground}" StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,8,0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <TextBlock Text="LOGOUT" FontSize="12" VerticalAlignment="Center" FontWeight="Bold" Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="COURIER PROFILE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Color_TextSecondary}"/>
                        <TextBlock Text="{Binding CurrentCourier.Name, StringFormat='Hello, {0}'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Color_Accent}" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding CurrentCourier.Id, StringFormat='ID: {0}'}" FontSize="13" Foreground="{StaticResource Color_TextSecondary}"/>
                    </StackPanel>
                </Grid>

                <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource Color_Border}" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="PERSONAL DETAILS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Color_TextSecondary}" Margin="0,0,0,15"/>

                        <Label Content="Full Name" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Name}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,15" Padding="10,8" Background="#F9FAFB" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" behavior:InputValidators.IsLettersOnly="True"/>

                        <Label Content="Phone Number" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Phone}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,15" Padding="10,8" Background="#F9FAFB" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" behavior:InputValidators.IsNumeric="True"/>

                        <Label Content="Email Address" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Email}" Style="{StaticResource BaseTextStyle}" Margin="0,0,0,25" Padding="10,8" Background="#F9FAFB" BorderBrush="{StaticResource Color_Border}" BorderThickness="1"/>

                        <TextBlock Text="DELIVERY PREFERENCES" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Color_TextSecondary}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Max Distance (km)" Style="{StaticResource LabelTitleStyle}"/>
                                <TextBox Text="{Binding CurrentCourier.MaxDistance}" Style="{StaticResource BaseTextStyle}" Padding="10,8" Background="#F9FAFB" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" behavior:InputValidators.IsNumeric="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Shipment Type" Style="{StaticResource LabelTitleStyle}"/>
                                <ComboBox SelectedItem="{Binding CurrentCourier.ShipmentType}" ItemsSource="{Binding Source={StaticResource ShipmentTypeKey}, Converter={StaticResource EnumFilterConverter}}" Style="{StaticResource ThemeComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#EFF6FF" CornerRadius="8" Padding="15" Margin="0,15,0,0" BorderBrush="#BFDBFE" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="On Time" FontSize="11" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentCourier.OrdersDeliveredInTime}" FontSize="24" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Rectangle Grid.Column="1" Fill="#BFDBFE" Margin="0,5"/>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="Late" FontSize="11" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentCourier.OrdersDeliveredAfterTime}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Color_BorderForDelete}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                            <Label Content="Active Status:" Style="{StaticResource LabelTitleStyle}"/>
                            <CheckBox Style="{StaticResource ToggleSwitchStyle}" IsChecked="{Binding CurrentCourier.IsActive}" IsHitTestVisible="False" Margin="10,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                            <TextBlock Text="Member since: " FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                            <TextBlock Text="{Binding CurrentCourier.StartTime, StringFormat='{}{0:dd/MM/yyyy}'}" FontSize="11" Foreground="{StaticResource Color_TextSecondary}" FontWeight="SemiBold"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="3" Content="Save Changes" Click="UpdateDetails_Click" Style="{StaticResource ThemeButton}" Margin="0,20,0,0" Padding="10,12"/>
            </Grid>
        </Border>


        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="WORKSPACE STATUS" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Color_TextMain}" VerticalAlignment="Center"/>
                <Button Style="{StaticResource LogoutButton}" Click="Logout_Click" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <Border Grid.Row="1" Grid.RowSpan="2" Background="#99FFFFFF" CornerRadius="12" Visibility="{Binding IsLoadInProgress, Converter={StaticResource BoolToVis}}" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Loading Data..." FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Color_Accent}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <ProgressBar IsIndeterminate="True" Height="6" Width="200" Foreground="{StaticResource Color_Accent}" Background="#E5E7EB" BorderThickness="0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Visibility="{Binding IsLoadInProgress, Converter={StaticResource BoolToCollapsed}}">

                <Border Style="{StaticResource CardStyle}" Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource NullToVisibleConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="AVAILABLE ORDERS FOR YOU" Style="{StaticResource CardHeaderStyle}"/>

                        <DataGrid Grid.Row="1" x:Name="dgOpenOrders" ItemsSource="{Binding OpenOrderList}" SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                                  SelectionMode="Single" IsReadOnly="True" MouseDoubleClick="doubleClick_OrderList" Style="{StaticResource ThemeDataGrid}"
                                  MinHeight="200" MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding OrderId}" Header="Order ID" Width="80"/>
                                <DataGridTextColumn Binding="{Binding OrderType}" Header="Type" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding ScheduleStatus}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ScheduleStatus, Converter={StaticResource StatusToColorConverter}}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding EstimatedArrivalTime, StringFormat=hh\\:mm}" Header="ETA" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Margin="0,20,0,0" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,10" DataContext="{Binding ElementName=dgOpenOrders, Path=SelectedItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,30,0">
                                        <TextBlock Text="📦 Weight" FontSize="12" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding Weight, TargetNullValue='--'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,30,0">
                                        <TextBlock Text="📏 Volume" FontSize="12" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding Volume, TargetNullValue='--'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,30,0">
                                        <TextBlock Text="📍 Distance" FontSize="12" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding ActualDistance, StringFormat='{}{0:N2} km', TargetNullValue='--'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Color_Accent}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="⏱️ Time Left" FontSize="12" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding TimeLeftToDeadline, StringFormat=hh\\:mm, TargetNullValue='--'}" FontSize="18" FontWeight="Bold" Foreground="#EF4444" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </WrapPanel>

                                <Button Grid.Column="1" Content="ACCEPT ORDER" Click="SelectOrder_Click" Style="{StaticResource ThemeButton}" Padding="30,12" FontSize="13" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" BorderBrush="{StaticResource Color_Accent}" BorderThickness="2" 
                        Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource StatusToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="ACTIVE DELIVERY IN PROGRESS" Style="{StaticResource CardHeaderStyle}" Foreground="{StaticResource Color_Accent}"/>
                            <Ellipse Width="10" Height="10" Fill="{StaticResource Color_Accent}" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="CUSTOMER &amp; DESTINATION" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Color_TextSecondary}" Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerName}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}"/>
                                <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerPhone}" FontSize="14" Foreground="{StaticResource Color_TextSecondary}" Margin="0,2,0,10"/>

                                <Border Background="#F9FAFB" CornerRadius="6" Padding="12" BorderThickness="1" BorderBrush="{StaticResource Color_Border}">
                                    <StackPanel>
                                        <TextBlock Text="Delivery Address:" FontSize="11" Foreground="{StaticResource Color_TextSecondary}" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerAddress}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Special Notes:" FontSize="11" Foreground="{StaticResource Color_TextSecondary}" Margin="0,15,0,2"/>
                                <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerDescription, TargetNullValue='No special notes provided.'}" FontSize="13" FontStyle="Italic" Foreground="{StaticResource Color_TextSecondary}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Fill="{StaticResource Color_Border}" Margin="0,10"/>

                            <StackPanel Grid.Column="2" Margin="20,0,0,0">
                                <TextBlock Text="DELIVERY METRICS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Color_TextSecondary}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Order ID" FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.OrderId}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Delivery ID" FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.DeliveryId}" FontSize="15" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Started At" FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.DeliveryStart, StringFormat='HH:mm'}" FontSize="16" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ETA" FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.ExpectedArrivalTime, StringFormat='HH:mm'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Color_Accent}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Deadline" FontSize="11" Foreground="{StaticResource Color_TextSecondary}"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.LastArrivalTime, StringFormat='HH:mm'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Color_BorderForDelete}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Background="#EFF6FF" CornerRadius="6" Padding="12" Margin="0,15,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Remaining Distance:" FontSize="13" Foreground="{StaticResource Color_Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding CurrentCourier.InProgress.RealDistance, StringFormat='{}{0:N1} km', TargetNullValue='--'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Color_Accent}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,25,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Client Not Found" Click="CustomerUnavailable_Click" Style="{StaticResource DeleteButton}"/>
                            <Button Grid.Column="2" Content="Refused" Click="DeliveryRefused_Click" Style="{StaticResource DeleteButton}"/>
                            <Button Grid.Column="4" Content="FINISH DELIVERY" Click="FinishDelivery_Click" Style="{StaticResource ThemeButton}" FontSize="16"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="YOUR DELIVERY HISTORY" Style="{StaticResource CardHeaderStyle}"/>

                    <DataGrid Grid.Row="1" IsReadOnly="True" ItemsSource="{Binding CloseOrderList}" Style="{StaticResource ThemeDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding DeliveryId}" Header="Delivery ID" Width="80"/>
                            <DataGridTextColumn Binding="{Binding OrderId}" Header="Order ID" Width="80"/>
                            <DataGridTextColumn Binding="{Binding Address}" Header="Destination" Width="2*"/>
                            <DataGridTextColumn Binding="{Binding ActualDistance, StringFormat='{}{0:N2} km'}" Header="Distance" Width="100"/>
                            <DataGridTextColumn Binding="{Binding ProcessingDuration, StringFormat=hh\\:mm}" Header="Duration" Width="80"/>
                            <DataGridTextColumn Binding="{Binding FinishType}" Header="Result" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>