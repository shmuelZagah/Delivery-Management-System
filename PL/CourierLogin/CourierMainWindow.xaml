<Window x:Class="PL.CourierLogin.CourierMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.CourierLogin"
        mc:Ignorable="d"
        Height="1080" Width="1920"
        Style="{StaticResource CyberWindowTheme}"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        xmlns:Items="clr-namespace:PL.Helpers.Items"
        
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--==================-->
            <!--#region User data -->
            <!--==================-->

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                <Items:Icon Width="30" Height="30" HorizontalAlignment="Left"/>

                <Button Content="Logout" 
                HorizontalAlignment="Left" 
                Width="80" Height="25" 
                Click="Logout_Click"
                Margin="20,0,0,0"
                />
            </StackPanel>


            <!--Titel-->
            <Label Grid.Row="1" Content="{Binding CurrentCourier.Name}" ContentStringFormat="Hello {0}" FontSize="24" FontWeight="Bold" 
               Foreground="{StaticResource Color_Accent}"/>


            <!--Higher Grid-->
            <Border Grid.Row="2" BorderBrush="{StaticResource Color_Border}" 
                BorderThickness="1" CornerRadius="5"
                Padding="15" Margin="0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--Left side-->
                        <Label Content="Id:" Grid.Row="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.Id}" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"
                               Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Content="Name:" Grid.Row="1" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Name}" Grid.Row="1" Grid.Column="1" 
                              VerticalAlignment="Center" Margin="5" Padding="5"
                             behavior:InputValidators.IsLettersOnly="True"/>

                        <Label Content="Phone:" Grid.Row="2" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Phone}" Grid.Row="2" Grid.Column="1" 
                              VerticalAlignment="Center" Margin="5" Padding="5"
                             behavior:InputValidators.IsNumeric="True"/>

                        <Label Content="Email:" Grid.Row="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Text="{Binding CurrentCourier.Email}" Grid.Row="3" Grid.Column="1" 
                              VerticalAlignment="Center" Margin="5" Padding="5"/>

                        <Label Content="deliverd on Time/Late:" Grid.Row="4" Style="{StaticResource LabelTitleStyle}"/>
                        <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentCourier.OrdersDeliveredInTime}" Foreground="LightGreen" Margin="5"/>
                            <TextBlock Text="/" Foreground="Gray" Margin="2"/>
                            <TextBlock Text="{Binding CurrentCourier.OrdersDeliveredAfterTime}" Foreground="Red" Margin="5"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource Color_Border}" Margin="20,5"/>



                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--Right side-->
                        <Label Content="Max distance:" Grid.Row="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CurrentCourier.MaxDistance}" 
                             VerticalAlignment="Center" Margin="5" Padding="5"
                             behavior:InputValidators.IsNumeric="True"/>

                        <Label Content="Shipment Type:" Grid.Row="1" Style="{StaticResource LabelTitleStyle}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" 
                              SelectedItem="{Binding CurrentCourier.ShipmentType}"
                              ItemsSource="{Binding Source={StaticResource ShipmentTypeKey}, Converter={StaticResource EnumFilterConverter}}"
                              Margin="5" VerticalAlignment="Center"/>


                        <Label Content="Start Time:" Grid.Row="2" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding CurrentCourier.StartTime, StringFormat='dd/MM/yyyy'}" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"/>

                        <Label Content="Active:" Grid.Row="3" Style="{StaticResource LabelTitleStyle}"/>
                        <CheckBox Grid.Row="3" Grid.Column="4" Style="{StaticResource ToggleSwitchStyle}"
                              HorizontalAlignment="Center"
                             IsChecked="{Binding CurrentCourier.IsActive}"
                           IsHitTestVisible="False"/>

                        <Button Grid.Row="4"  Content="update"  HorizontalAlignment="Stretch"  VerticalAlignment="Bottom"  Height="25" Click="UpdateDetails_Click"
                                TextBlock.TextAlignment="Center" Grid.ColumnSpan="2" FontSize="12"/>
                    </Grid>

                </Grid>
            </Border>





            <!--#endregion-->
            <!--==================-->


            <!--=========================-->
            <!--#region Delivery History-->
            <!--=========================-->

            <GroupBox Header="Delivery History" Grid.Row="4">
                <DataGrid IsReadOnly="True"
                          HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                          ItemsSource="{Binding CloseOrderList}"
                         >
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding DeliveryId}" Header="Delivery Id" Width="*"/>
                        <DataGridTextColumn Binding="{Binding OrderId}" Header="Order Id" Width="*"/>
                        <DataGridTextColumn Binding="{Binding OrderType}" Header="Order Type" Width="*"/>
                        <DataGridTextColumn Binding="{Binding Address}" Header="Address" Width="*"/>
                        <DataGridTextColumn Binding="{Binding ShipmentType}" Header="Shipment" Width="*"/>
                        <DataGridTextColumn Binding="{Binding ActualDistance, StringFormat=N2}" Header="Distance" Width="*"/>
                        <DataGridTextColumn Binding="{Binding ProcessingDuration, StringFormat=hh\\:mm}" Header="Duration" Width="*"/>
                        <DataGridTextColumn Binding="{Binding FinishType}" Header="How ended" Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>
            </GroupBox>


            <!--#endregion-->
            <!--=========================-->

        </Grid>


        <!-- Loading overlay for the right panel (only on first load) -->
        <Border Grid.Column="2"
                 Background="#66000000"
                 CornerRadius="12"
                 Visibility="{Binding IsLoadInProgress, Converter={StaticResource BoolToVis}}"
                 Panel.ZIndex="9999">

            <StackPanel HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Width="280"
                 Margin="20">

                <TextBlock Text="טוען הזמנות"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="White"
                HorizontalAlignment="Center"
                Margin="0,0,0,12"/>

                <ProgressBar IsIndeterminate="True" Height="12">
                    <ProgressBar.Foreground>
                        <LinearGradientBrush EndPoint="1,0" StartPoint="0,0">
                            <GradientStop Color="#FFE6E6E6"/>
                            <GradientStop Color="#FF1C87C6" Offset="0.625"/>
                        </LinearGradientBrush>
                    </ProgressBar.Foreground>
                </ProgressBar>

                <TextBlock Text="רק רגע 🙂"
                Foreground="#DDDDDD"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2" Visibility="{Binding IsLoadInProgress, Converter={StaticResource BoolToCollapsed}}" >
            <!--=========================-->
            <!--#region Order Selection-->
            <!--=========================-->

            <GroupBox Header="Delivery Actions"  Margin="5" BorderBrush="#444444" 
                      Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource NullToVisibleConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgOpenOrders"
                  Grid.Row="0"
                  ItemsSource="{Binding OpenOrderList}"
                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                  MouseDoubleClick="doubleClick_OrderList">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding OrderId}" Header="Order Id" Width="*"/>
                            <DataGridTextColumn Binding="{Binding OrderType}" Header="Order Type" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding ScheduleStatus}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ScheduleStatus, Converter={StaticResource StatusToColorConverter}}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding EstimatedArrivalTime, StringFormat=hh\\:mm}"  Header="ETA" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Separator Grid.Row="1" Background="#444444" Margin="10"/>

                    <Grid Grid.Row="2" Margin="10" 
              DataContext="{Binding ElementName=dgOpenOrders, Path=SelectedItem}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Weight:" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Weight}" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Grid.Row="0" Grid.Column="3" Content="Volume:" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding Volume}" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Distance:" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ActualDistance, StringFormat=N2, TargetNullValue='--'}" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Grid.Row="1" Grid.Column="3" Content="Time Left:" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding TimeLeftToDeadline, StringFormat=hh\\:mm}" Style="{StaticResource ReadOnlyTextStyle}"/>
                    </Grid>

                    <Border Grid.Row="3" 
                Margin="20"
                Height="200" Width="200"
                CornerRadius="100" 
                BorderThickness="2"
                BorderBrush="{StaticResource Color_Accent}"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center">

                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#222" Offset="1"/>
                                <GradientStop Color="#333" Offset="0"/>
                            </RadialGradientBrush>
                        </Border.Background>

                        <TextBlock Text="Map Area" 
                       Foreground="#666" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"/>
                    </Border>

                    <Button Grid.Row="4" Content="Select Order" 
                 Height="35" Margin="0,10,0,0"
                 Click="SelectOrder_Click"/>
                </Grid>
            </GroupBox>


            <!--#endregion -->
            <!--=========================-->

            <!--=========================-->
            <!--#region Order Handling-->
            <!--=========================-->


            <GroupBox Header="Order In Progress" Margin="5" BorderBrush="#444444" 
          Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource StatusToVisibilityConverter}}">

                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="My Delivery" Style="{StaticResource LabelTitleStyle}" FontSize="28"/>
                    <Separator Grid.Row="1" Margin="0,5" Background="#444444"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Customer Info" Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource LabelTitleStyle}" FontSize="18"/>

                        <Label Content="Customer Name:" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerName}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Content="Phone:" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerPhone}" Grid.Row="2" Grid.Column="1" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Content="Address:" Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelTitleStyle}" VerticalAlignment="Top"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerAddress}" Grid.Row="3" Grid.Column="1" 
                       Style="{StaticResource ReadOnlyTextStyle}" TextWrapping="Wrap" MaxHeight="35" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                    </Grid>

                    <Separator Grid.Row="3" Margin="0,5" Background="#444444"/>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Order Info" Grid.Row="0" Grid.ColumnSpan="5" Style="{StaticResource LabelTitleStyle}" FontSize="18"/>

                        <Label Content="Order ID:" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.OrderId}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Content="Order Created:" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.OrderCreated, StringFormat='dd/MM HH:mm'}" Grid.Row="2" Grid.Column="1"/>

                        <Label Content="Type:" Grid.Row="1" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.OrderType}" Grid.Row="1" Grid.Column="4" Style="{StaticResource ReadOnlyTextStyle}"/>

                        <Label Content="Schedule:" Grid.Row="2" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.ScheduleStatus, Converter={StaticResource GlobalEnumConverter}}" Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="4"  
                    Foreground="{Binding CurrentCourier.InProgress.ScheduleStatus, Converter={StaticResource StatusToColorConverter}}"/>

                    </Grid>

                    <Separator Grid.Row="5" Margin="0,5" Background="#444444"/>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Delivery Info" Grid.Row="0" Grid.ColumnSpan="5" Style="{StaticResource LabelTitleStyle}" FontSize="18"/>

                        <Label Content="Delivery Id" Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.DeliveryId}" Grid.Row="1" Grid.Column="1"/>

                        <Label Content="Delivery Startd at:" Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.DeliveryStart, StringFormat='HH:mm'}" Grid.Row="2" Grid.Column="1"/>

                        <Label Content="ETA:" Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.ExpectedArrivalTime, StringFormat='HH:mm'}" Grid.Row="3" Grid.Column="1"/>

                        <Label Content="Deadline:" Grid.Row="1" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.LastArrivalTime, StringFormat='HH:mm'}" Grid.Row="1" Grid.Column="4"/>

                        <Label Content="Time left to Deadline:" Grid.Row="2" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.TimeGap, StringFormat='hh\\:mm'}" Grid.Row="2" Grid.Column="4"/>

                        <Label Content="Air Distance:" Grid.Row="3" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.AirDistance, StringFormat='{}{0:N1} km'}" Grid.Row="3" Grid.Column="4"/>

                        <Label Content="Your Distance:" Grid.Row="4" Grid.Column="3" Style="{StaticResource LabelTitleStyle}"/>
                        <TextBlock Text="{Binding CurrentCourier.InProgress.RealDistance, StringFormat='{}{0:N1} km', TargetNullValue='--'}" Grid.Row="4" Grid.Column="4"/>





                    </Grid>

                    <Separator Grid.Row="7" Margin="0,5" Background="#444444"/>

                    <StackPanel Grid.Row="8">
                        <Label Content="Notes:" Style="{StaticResource LabelTitleStyle}"/>
                        <Border BorderBrush="#333333" BorderThickness="1" Background="#151515" CornerRadius="3" Padding="4" MinHeight="40">
                            <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerDescription, TargetNullValue='No special notes'}" 
                           Style="{StaticResource ReadOnlyTextStyle}" 
                           TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA"/>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="10" Height="35" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button  Grid.Column="0" Content="Customer Unavailable" Click="CustomerUnavailable_Click" Style="{StaticResource DeleteButton}"/>
                        <Button  Grid.Column="1" Content="Finish Delivery" Click="FinishDelivery_Click"/>
                        <Button  Grid.Column="2" Content="Delivery Refused" Click="DeliveryRefused_Click" Style="{StaticResource DeleteButton}"/>


                    </Grid>


                </Grid>
            </GroupBox>
            <!--#endregion-->
            <!--=========================-->
        </Grid>
    </Grid>

</Window>
