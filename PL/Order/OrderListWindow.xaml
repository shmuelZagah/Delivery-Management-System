<Window x:Class="PL.Order.OrderListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Order"
        mc:Ignorable="d"
        Title="Order List" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Style="{StaticResource CyberWindowTheme}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        >

    <!---External Grid-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="500*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Internal, Upper Grid-->
        <Grid HorizontalAlignment="Stretch" Height="Auto" Grid.Row="0" VerticalAlignment="Stretch" 
Width="Auto">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label 
                Grid.Column="0"
                Content="Filter by"
                HorizontalAlignment="Center"
                Margin="10,0,0,0"
                VerticalAlignment="Center"/>


            <ComboBox
                Grid.Column="1" 
                VerticalAlignment="Center" 
                Width="150"
                ItemsSource="{Binding OrderOptionsList}"
                SelectedValue="{Binding SelectedOption, Mode=TwoWay}"
                SelectionChanged="FirstCombo_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource GlobalEnumConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox
                Grid.Column="2" 
                VerticalAlignment="Center" 
                Width="150" 
                Margin="10,0,0,0"
                ItemsSource="{Binding OptionsFilterList}"
                SelectedValue="{Binding SelectedFilterValue}" 
                SelectionChanged="SecondCombo_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource GlobalEnumConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Grid.Column="4" VerticalAlignment="Center" Margin="10,0">
                <Label Content="Group By:" FontWeight="Bold"/>

                <ComboBox x:Name="cmbGroup" 
              Width="150" 
              SelectionChanged="CmbGroup_SelectionChanged"
              VerticalAlignment="Center">

                    <ComboBoxItem Content="None" IsSelected="True"/>
                    <ComboBoxItem Content="Order Status"/>
                    <ComboBoxItem Content="Order Type"/>
                    <ComboBoxItem Content="Schedule Status"/>
                </ComboBox>
            </StackPanel>

        </Grid>
        <DataGrid Grid.Row="1"
            IsReadOnly ="True"
            AutoGenerateColumns="false"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Center"      
   	        EnableRowVirtualization="True" 
            RowDetailsVisibilityMode="VisibleWhenSelected"
                  
            MouseDoubleClick="dgOrderList_MouseDoubleClick"

            ItemsSource="{Binding OrderList}"
            SelectedItem="{Binding SelectedOrder}">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding OrderId}" Header="Order Id" Width="*"/>
                <DataGridTextColumn Binding="{Binding DeliveryId}" Header="Delivery Id" Width="*"/>
                <DataGridTextColumn Binding="{Binding OrderType}" Header="Order Type" Width="*"/>
                <DataGridTextColumn Binding="{Binding OrderStatus, Converter={StaticResource GlobalEnumConverter}}" Header="Order Status" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{Binding OrderStatus, Converter={StaticResource StatusToColorConverter}}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding AirDistance,StringFormat='{}{0:N2} km' }" Header="AirDistance" Width="*"/>
                        <DataGridTextColumn Binding="{Binding ScheduleStatus, Converter={StaticResource GlobalEnumConverter}}" Header="Status" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding ScheduleStatus, Converter={StaticResource StatusToColorConverter}}" />
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding TimeLeftToDeadline ,StringFormat=\{0:hh\\:mm\}}" Header="Time Left To Dead line" Width="*"/>
                        <DataGridTextColumn Binding="{Binding TimeTookToFinish, StringFormat=\{0:hh\\:mm\}}" Header="Time Took To Finish" Width="*"/>
                        <DataGridTextColumn Binding="{Binding CouriersCount}" Header="Couriers Count" Width="*"/>



                        <!-- delete button -->
                        <DataGridTemplateColumn Header="delete" Width="70" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                            <Button Content="Cancel" 
                             ToolTip="Delete Item"
                             Click="btnDelete_Click" 
                             Width="60" 
                             Background="Transparent" 
                             Visibility="{Binding OrderStatus, Converter={StaticResource StatusToVisibilityConverter}}"
                             HorizontalAlignment="Center"/>
                        </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Add" Grid.Row="2" HorizontalAlignment="Center" Height="50" Width="100" Click="btnAdd_Click"/>

    </Grid>

</Window>



     