<Window x:Class="PL.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        xmlns:Items="clr-namespace:PL.Helpers.Items"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="LoginWindow" Height="450" Width="800"
        Style="{StaticResource CyberWindowTheme}"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        WindowStartupLocation="CenterScreen"
      >
    <Grid>

        <!--Welcome-->
        <Label HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Content="Welcome"  Margin="0,49,0,0" 
               Width="400" Height="100"
               FontSize="65" FontWeight="Bold" FontFamily="Castellar" Background="Transparent"
               HorizontalContentAlignment="Center"
               VerticalContentAlignment="Center" RenderTransformOrigin="0.5,0.5" >
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Gray" />
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>



        <Label
        VerticalAlignment="Top"
        Content="Please enter your ID and password to login"  Margin="0,113,0,0" 
        Width="442" Height="100"
        FontSize="20" FontFamily="Book Antiqua" Background="Transparent"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center" RenderTransformOrigin="0.5,0.5"
        >
            <Label.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Gray" />
                    <GradientStop Color="White" Offset="1"/>
                </LinearGradientBrush>
            </Label.Foreground>
        </Label>

        <!--icon-->
        <Items:Icon
            HorizontalAlignment="Right"
            Margin="10"
            VerticalAlignment="Top"/>
        
        <!--INPUT-->
        <TextBlock HorizontalAlignment="Center" Margin="0,232,0,0"
                 TextWrapping="Wrap" Text="Enter username" VerticalAlignment="Top"
                 Height="21" Width="190" RenderTransformOrigin="0.5,0.5"
                TextAlignment="Center" Foreground="#FFABABAB" FontFamily="SimSun"
                 >
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsThereIsInput}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>

        </TextBlock>

        <TextBox Background="Transparent" Margin="0,225,0,0"  CaretBrush="White" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                 VerticalAlignment="Top" Width="190" Height="30" BorderThickness="0" FontSize="16"
                  Foreground="{Binding Text, RelativeSource={RelativeSource Self}, Converter={StaticResource InputNumToColorConvert}}"/>
        <Rectangle HorizontalAlignment="Center" Height="3" Margin="0,250,0,0" Stroke="#0080E0" Fill="#0080E0" VerticalAlignment="Top" Width="198"/>

        <TextBlock x:Name="passEnter" HorizontalAlignment="Center" Margin="0,275,0,0"
            TextWrapping="Wrap" Text="Enter password" VerticalAlignment="Top"
            Height="21" Width="190" RenderTransformOrigin="0.5,0.5"
           TextAlignment="Center" Foreground="#FFABABAB" FontFamily="SimSun"/>

        <PasswordBox x:Name="password" Background="Transparent" HorizontalAlignment="Center" Margin="0,265,0,0" VerticalAlignment="Top" CaretBrush="White"
                     Width="190" Height="30" BorderThickness="0" FontSize="16" PasswordChanged="userPass_TextChanged" Foreground="White" />

        <Rectangle HorizontalAlignment="Center" Height="3" Margin="0,290,0,0"
                   Stroke="#00ADEF" Fill="#00ADEF" VerticalAlignment="Top" Width="198"/>

        <!--Login-->
        <Button Content="Login" IsDefault="True" HorizontalAlignment="Center" Margin="0,340,0,0" VerticalAlignment="Top"
                RenderTransformOrigin="0.5,0.5" BorderBrush="#FF3B4968" Width="70" Height="20" Click="Button_Click">

        </Button>


        <TextBlock x:Name="Excep" HorizontalAlignment="Center" Margin="0,381,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" >
            <TextBlock.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="White"/>
                    <GradientStop Color="#FF950B0B" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
        </TextBlock>

    </Grid>
</Window>
