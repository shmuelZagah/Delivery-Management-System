<Window x:Class="PL.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="System Login" Height="600" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
    <Window.Resources>
        <Storyboard x:Key="EntranceAnimation">
            <DoubleAnimation Storyboard.TargetName="MainCard" Storyboard.TargetProperty="Opacity" 
                             From="0" To="1" Duration="0:0:1.5"/>

            <DoubleAnimation Storyboard.TargetName="CardTranslate" Storyboard.TargetProperty="Y" 
                             From="80" To="0" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX" 
                             From="0.9" To="1" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY" 
                             From="0.9" To="1" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="AmbientAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="Orb1Translate" Storyboard.TargetProperty="Y" 
                             From="0" To="-40" Duration="0:0:6">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Orb1Translate" Storyboard.TargetProperty="X" 
                             From="0" To="30" Duration="0:0:8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="Orb2Translate" Storyboard.TargetProperty="Y" 
                             From="0" To="50" Duration="0:0:7">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntranceAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource AmbientAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid>
            <Path Data="M0,200 C300,400 600,0 950,200 L950,600 L0,600 Z" Opacity="0.05">
                <Path.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#005FB8" Offset="0"/>
                        <GradientStop Color="#00ADEF" Offset="1"/>
                    </LinearGradientBrush>
                </Path.Fill>
            </Path>
            <Path Data="M0,400 C400,200 700,500 950,300 L950,600 L0,600 Z" Opacity="0.08" Fill="{StaticResource Color_Accent}"/>

            <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-200,-200" Opacity="0.12">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#00ADEF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb1Translate" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse Width="450" Height="450" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-150,0,0" Opacity="0.10">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#005FB8" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb2Translate" X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Grid>

        <Border x:Name="MainCard" HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="440" Padding="40,50"
                Background="{StaticResource Color_Control}" 
                CornerRadius="20" Opacity="0">

            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="CardScale" ScaleX="0.9" ScaleY="0.9" CenterX="220" CenterY="250"/>
                    <TranslateTransform x:Name="CardTranslate" Y="80"/>
                </TransformGroup>
            </Border.RenderTransform>

            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.35" BlurRadius="50" ShadowDepth="20" Direction="270"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Welcome Back" 
                           FontSize="36" FontWeight="Black" Foreground="{StaticResource Color_TextMain}" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Please sign in to your dashboard" 
                           FontSize="15" Foreground="{StaticResource Color_TextSecondary}" 
                           HorizontalAlignment="Center" Margin="0,0,0,45"/>

                <Grid Margin="0,0,0,25">
                    <TextBlock Text="User ID" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" Margin="5,0,0,45"/>
                    <Border Background="#F3F4F6" CornerRadius="8" Height="45" Margin="0,20,0,0">
                        <Grid>
                            <TextBox x:Name="txtUsername" 
                                     Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" 
                                     VerticalContentAlignment="Center" FontSize="15" FontWeight="SemiBold"
                                     Padding="15,0" Background="Transparent" BorderThickness="0"
                                     Foreground="{StaticResource Color_TextMain}" CaretBrush="{StaticResource Color_Accent}"/>

                            <TextBlock Text="Enter your numeric ID" 
                                       Foreground="#9CA3AF" VerticalAlignment="Center" Margin="16,0,0,0" 
                                       IsHitTestVisible="False" FontSize="14" FontWeight="Normal">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThereIsInput}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Password" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" Margin="5,0,0,45"/>
                    <Border Background="#F3F4F6" CornerRadius="8" Height="45" Margin="0,20,0,0">
                        <Grid>
                            <PasswordBox x:Name="password" 
                                         PasswordChanged="userPass_TextChanged"
                                         VerticalContentAlignment="Center" FontSize="15" FontWeight="SemiBold"
                                         Padding="15,0" Background="Transparent" BorderThickness="0"
                                         Foreground="{StaticResource Color_TextMain}" CaretBrush="{StaticResource Color_Accent}"/>

                            <TextBlock x:Name="passEnter" Text="Enter your password" 
                                       Foreground="#9CA3AF" VerticalAlignment="Center" Margin="16,0,0,0" 
                                       IsHitTestVisible="False" FontSize="14" FontWeight="Normal"/>
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock x:Name="Excep" 
                           Foreground="{StaticResource Color_BorderForDelete}" 
                           TextWrapping="Wrap" Margin="0,0,0,20" 
                           FontWeight="Bold" TextAlignment="Center" 
                           MinHeight="20" FontSize="13"/>

                <Button Content="Login to System" 
                        IsDefault="True" 
                        Height="52" 
                        Click="Button_Click" 
                        Style="{StaticResource ThemeButton}"
                        FontSize="17" FontWeight="Bold"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>