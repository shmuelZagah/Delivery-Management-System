<Window x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        Title="Admin Dashboard" Height="850" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Style="{StaticResource CyberWindowTheme}"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <Style x:Key="ClockArrowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Color_Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="EntranceAnimation">
            <DoubleAnimation Storyboard.TargetName="MainContentGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.2"/>
            <DoubleAnimation Storyboard.TargetName="DashboardTranslate" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="AmbientAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AmbientLight1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:15" Value="150">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AmbientLight1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:20" Value="-80">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AmbientLight2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:18" Value="-120">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AmbientLight2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:25" Value="100">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimation Storyboard.TargetName="Beacon1Scale" Storyboard.TargetProperty="ScaleX" From="0" To="5" Duration="0:0:6" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Beacon1Scale" Storyboard.TargetProperty="ScaleY" From="0" To="5" Duration="0:0:6" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Beacon1" Storyboard.TargetProperty="Opacity" From="0.3" To="0" Duration="0:0:6" RepeatBehavior="Forever"/>

            <DoubleAnimation Storyboard.TargetName="Beacon2Scale" Storyboard.TargetProperty="ScaleX" From="0" To="6" Duration="0:0:8" RepeatBehavior="Forever" BeginTime="0:0:3"/>
            <DoubleAnimation Storyboard.TargetName="Beacon2Scale" Storyboard.TargetProperty="ScaleY" From="0" To="6" Duration="0:0:8" RepeatBehavior="Forever" BeginTime="0:0:3"/>
            <DoubleAnimation Storyboard.TargetName="Beacon2" Storyboard.TargetProperty="Opacity" From="0.2" To="0" Duration="0:0:8" RepeatBehavior="Forever" BeginTime="0:0:3"/>
        </Storyboard>

        <SolidColorBrush x:Key="CyberYellowBrush" Color="#FBBF24"/>
        <SolidColorBrush x:Key="CyberGreenBrush" Color="#34D399"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Color_TextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="15,8" CornerRadius="8" x:Name="border">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2 L12,12 M7,5 A8,8 0 1,0 17,5" Stroke="{TemplateBinding Foreground}" StrokeThickness="2" VerticalAlignment="Center" Margin="0,0,8,0" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <TextBlock Text="LOGOUT" FontSize="12" VerticalAlignment="Center" FontWeight="Bold" Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalApplyButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Color_Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="15,0">
                            <TextBlock Text="Save" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A005FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatGaugeContainer" TargetType="Border">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="CornerRadius" Value="55"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathIcon" TargetType="Path">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
        </Style>

        <Style x:Key="AnimatedDbPanelStyle" TargetType="StackPanel">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.0" Duration="0:0:0.4" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="10" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="IsHitTestVisible">
                                    <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                                </BooleanAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.4">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="IsHitTestVisible">
                                    <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                </BooleanAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource EntranceAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource AmbientAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Path Data="M0,100 C500,50 1000,400 1920,200 L1920,1080 L0,1080 Z" Opacity="0.04" Fill="{StaticResource Color_Accent}"/>

        <Canvas IsHitTestVisible="False">
            <Ellipse x:Name="AmbientLight1" Width="800" Height="800" Fill="#00ADEF" Opacity="0.08" Canvas.Left="-200" Canvas.Top="-200">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="AmbientLight2" Width="600" Height="600" Fill="#005FB8" Opacity="0.08" Canvas.Right="-100" Canvas.Bottom="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="Beacon1" Width="100" Height="100" Stroke="#00ADEF" StrokeThickness="1" Canvas.Left="200" Canvas.Top="150" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="Beacon1Scale" ScaleX="0" ScaleY="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse x:Name="Beacon2" Width="120" Height="120" Stroke="#005FB8" StrokeThickness="1.5" Canvas.Right="250" Canvas.Bottom="200" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="Beacon2Scale" ScaleX="0" ScaleY="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Grid x:Name="MainContentGrid" Margin="40" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="DashboardTranslate" Y="30"/>
            </Grid.RenderTransform>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" CornerRadius="16" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,30">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="SYSTEM CLOCK" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                Click="btnToggleTimeEdit_Click" 
                IsEnabled="{Binding IsLocked}"
                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Path Data="M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z" 
                  Fill="{StaticResource Color_Accent}" 
                  Stretch="Uniform" Width="14" Height="14">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTimeEditMode}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>
                        </Grid>

                        <Border Background="#F9FAFB" CornerRadius="12" Padding="10,15" BorderBrush="{StaticResource Color_Border}" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel>
                                        <Button Content="▲" Style="{StaticResource ClockArrowButton}" FontSize="10"  Click="btnAddOneHour_Click" 
                            Visibility="{Binding IsTimeEditMode, Converter={StaticResource BoolToVisible}}"/>
                                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:HH}'}" FontSize="48" FontWeight="Light" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text=":" FontSize="36" FontWeight="Light" Foreground="{StaticResource Color_TextSecondary}" Margin="5,10" VerticalAlignment="Center"/>

                                    <StackPanel>
                                        <Button Content="▲" FontSize="10" Style="{StaticResource ClockArrowButton}" Click="btnAddOneMinute_Click" 
                            Visibility="{Binding IsTimeEditMode, Converter={StaticResource BoolToVisible}}"/>
                                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:mm}'}" FontSize="48" FontWeight="Light" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <Rectangle Height="1" Fill="{StaticResource Color_Border}" Margin="10,10" Opacity="0.5"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <StackPanel Width="40">
                                        <Button Content="▲" FontSize="8" Style="{StaticResource ClockArrowButton}" Click="btnAddOneDay_Click" 
                            Visibility="{Binding IsTimeEditMode, Converter={StaticResource BoolToVisible}}"/>
                                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:dd}'}" FontSize="16" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="DAY" FontSize="9" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="/" FontSize="14" Foreground="{StaticResource Color_Border}" Margin="4,15,4,0"/>
                                    <StackPanel Width="40">
                                        <Button Content="▲" FontSize="8" Style="{StaticResource ClockArrowButton}" Click="btnAddOneMonth_Click" 
                            Visibility="{Binding IsTimeEditMode, Converter={StaticResource BoolToVisible}}"/>
                                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:MM}'}" FontSize="16" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Text="MON" FontSize="9" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="/" FontSize="14" Foreground="{StaticResource Color_Border}" Margin="4,15,4,0"/>
                                    <StackPanel Width="50">
                                        <Button Content="▲" FontSize="8" Style="{StaticResource ClockArrowButton}" Click="btnAddOneYear_Click" 
                            Visibility="{Binding IsTimeEditMode, Converter={StaticResource BoolToVisible}}"/>
                                        <TextBlock Text="{Binding CurrentTime, StringFormat='{}{0:yyyy}'}" FontSize="16" Foreground="{StaticResource Color_Accent}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="YEAR" FontSize="9" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionHeaderStyle}"/>

                        <Button Style="{StaticResource ThemeButton}" Margin="0,5" Click="btnAddNewOrder_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White" Style="{StaticResource PathIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Create New Order" VerticalAlignment="Center" FontSize="13" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ThemeButton}" Margin="0,5" Click="btnHandleOrderTable_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.5,21.82C12.18,22 11.82,22 11.5,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.5,2.18C11.82,2 12.18,2 12.5,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L5,8.09L12,12.03L19,8.09L12,4.15M11,20.29V13.11L4,9.17V16.35L11,20.29M13,20.29L20,16.35V9.17L13,13.11V20.29Z" Fill="White" Style="{StaticResource PathIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Manage Orders" VerticalAlignment="Center" FontSize="13" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ThemeButton}" Margin="0,5" Click="btnHandleCourierTable_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" Fill="White" Style="{StaticResource PathIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Manage Couriers" VerticalAlignment="Center" FontSize="13" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Style="{StaticResource AnimatedDbPanelStyle}">
                        <TextBlock Text="DATABASE CONTROLS" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Initialize" Click="btnInitializeData_Click" Background="Transparent" Foreground="{StaticResource Color_TextSecondary}" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" Padding="5"/>
                            <Button Grid.Column="2" Content="Reset DB" Click="btnResetDatabase_Click" Background="Transparent" Foreground="#EF4444" BorderBrush="#33EF4444" BorderThickness="1" Padding="5"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <TextBlock Text="SIMULATION INTERVAL" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Interval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{StaticResource Color_TextMain}" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" IsReadOnly="{Binding IsRunning}" TextAlignment="Center" VerticalContentAlignment="Center" Height="34" Padding="10,0"/>
                            <Button Grid.Column="2" Content="{Binding ToggleText}" Click="btnSimultion_Click" Style="{StaticResource ThemeButton}" Width="100"/>
                        </Grid>
                    </StackPanel>

                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="EXECUTIVE STATUS" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Color_TextMain}" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource LogoutButton}" Click="Logout_Click" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,25">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="LIVE METRICS" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <WrapPanel Grid.Row="1" HorizontalAlignment="Center">

                            <StackPanel Margin="20,10">
                                <Border Style="{StaticResource StatGaugeContainer}" BorderBrush="#005FB8">
                                    <TextBlock Text="{Binding TotalOpen, StringFormat='{}{0:D2}'}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="OPEN" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Margin="20,10">
                                <Border Style="{StaticResource StatGaugeContainer}" BorderBrush="#FBBF24">
                                    <TextBlock Text="{Binding TotalInProgress, StringFormat='{}{0:D2}'}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="IN PROGRESS" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Margin="20,10">
                                <Border Style="{StaticResource StatGaugeContainer}" BorderBrush="#34D399">
                                    <TextBlock Text="{Binding TotalCompleted, StringFormat='{}{0:D2}'}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="COMPLETED" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Margin="20,10">
                                <Border Style="{StaticResource StatGaugeContainer}" BorderBrush="#EF4444">
                                    <TextBlock Text="{Binding TotalCanceled, StringFormat='{}{0:D2}'}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource Color_TextMain}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="CANCELED" Foreground="{StaticResource Color_TextSecondary}" HorizontalAlignment="Center" Margin="0,10,0,0" FontWeight="SemiBold"/>
                            </StackPanel>

                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" CornerRadius="12" Padding="35">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="SYSTEM CONFIGURATION" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,25"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="LOCATION &amp; RANGE" Foreground="{StaticResource Color_Accent}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,20"/>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Company Address" Foreground="{StaticResource Color_TextMain}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Configuration.CompanyAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{StaticResource Color_TextMain}" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" Height="34" VerticalContentAlignment="Center" Padding="10,0" />
                                    <Button Grid.Column="2" Click="btnApplyCompanyAddress_Click" Style="{StaticResource MinimalApplyButton}" Margin="5,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
