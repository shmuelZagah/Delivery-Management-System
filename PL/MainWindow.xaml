                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Walking Speed" Foreground="{StaticResource Color_TextMain}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Configuration.AvgWalkingSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" behavior:InputValidators.IsNumeric="True" Background="Transparent" Foreground="{StaticResource Color_TextMain}" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" Height="34" VerticalContentAlignment="Center" Padding="10,0"/>
