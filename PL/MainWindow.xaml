                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bicycle Speed" Foreground="{StaticResource Color_TextMain}" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Configuration.AvgBicycleSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" behavior:InputValidators.IsNumeric="True" Background="Transparent" Foreground="{StaticResource Color_TextMain}" BorderBrush="{StaticResource Color_Border}" BorderThickness="1" Height="34" VerticalContentAlignment="Center" Padding="10,0"/>
                                    <Button Grid.Column="2" Click="btnApplyAvgBicycleSpeed_Click" Style="{StaticResource MinimalApplyButton}" Margin="5,0,0,0"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
