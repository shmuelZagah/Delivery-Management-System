<Window x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Main Management Screen" Height="700" Width="950" DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Style="{StaticResource CyberWindowTheme}"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- System Clock Section -->
        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0 0 0 15" Margin="0 0 0 20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="System Clock:" 
                       VerticalAlignment="Center" 
                       FontWeight="Bold"
                       FontSize="14"/>
                <Label Grid.Column="1"
                       Content="{Binding CurrentTime}"
                       VerticalAlignment="Center"
                       FontSize="14" Width="99"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="30,0,0,0">
                    <Button Content="Advance Minute" Click="btnAddOneMinute_Click" Width="110" Margin="5" IsEnabled="{Binding IsLocked}"/>
                    <Button Content="Advance Hour"   Click="btnAddOneHour_Click" Width="110" Margin="5" IsEnabled="{Binding IsLocked}"/>
                    <Button Content="Advance Day"    Click="btnAddOneDay_Click" Width="110" Margin="5" IsEnabled="{Binding IsLocked}"/>
                    <Button Content="Advance Month"  Click="btnAddOneMonth_Click" Width="110" Margin="5" IsEnabled="{Binding IsLocked}"/>
                    <Button Content="Advance Year"   Click="btnAddOneYear_Click" Width="110" Margin="5" IsEnabled="{Binding IsLocked}"/>
                    <Button Content="{Binding ToggleText}"   Click="btnSimultion_Click" Width="95"/>
                    <TextBox Text="{Binding Interval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="50"
                             IsReadOnly ="{Binding IsRunning}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Configuration Variables Section -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="0 0 0 15" Margin="0 0 0 20">
            <StackPanel>
                <Label Content="Configuration Variables:"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0 0 0 15"/>
                <StackPanel Margin="0,0,0,10">
                    <!-- Company Address -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Company Address" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.CompanyAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyCompanyAddress_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Latitude -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Latitude" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.Latitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="10 0 0 0" Padding="5"
                                behavior:InputValidators.IsNumeric="True"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyLatitude_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Longitude -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Longitude" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.Longitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="10 0 0 0" Padding="5"
                                 behavior:InputValidators.IsNumeric="True"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyLongitude_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Max Air Range -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Max Air Range" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.MaxAirRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 behavior:InputValidators.IsNumeric="True"
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyMaxAirRange_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Avg Car Speed -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Car Speed" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.AvgCarSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 behavior:InputValidators.IsNumeric="True"
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyAvgCarSpeed_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Avg Motocycler Speed -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Motocycler Speed" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.AvgMotocyclerSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 behavior:InputValidators.IsNumeric="True"
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyAvgMotocyclerSpeed_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Avg Bicycle Speed -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Bicycle Speed" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.AvgBicycleSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 behavior:InputValidators.IsNumeric="True"
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyAvgBicycleSpeed_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>

                    <!-- Avg Walking Speed -->
                    <Grid Margin="0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Avg Walking Speed" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox Grid.Column="1" Text="{Binding Configuration.AvgWalkingSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 behavior:InputValidators.IsNumeric="True"
                                 Margin="10 0 0 0" Padding="5"/>
                        <Button Grid.Column="2" Content="Apply" Click="btnApplyAvgWalkingSpeed_Click" Width="60" Margin="10 0 0 0"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- System Buttons Section -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0"
                    >
            <Button Content="Logout" Click="Logout_Click" Width="100" Margin="10"/>
            <Button Content="Orders list" Click="btnHandleOrderTable_Click" Width="100" Margin="10" />
            <Button Content="Courier list" Click="btnHandleCourierTable_Click" Width="100" Margin="10"/>
            <Button Content="Initialize &#x0a; (Data Creation)" Click="btnInitializeData_Click" Width="100" Margin="10" TextBlock.TextAlignment="Center" IsEnabled="{Binding IsLocked}" />
            <Button Content="ResetDB  &#x0a; (Data Cleanup)" Click="btnResetDatabase_Click" Width="100" Margin="10" TextBlock.TextAlignment="Center" IsEnabled="{Binding IsLocked}"/>
        </StackPanel>
    </Grid>
</Window>