<Window x:Class="PL.Courier.CourierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Courier"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="650" Width="450"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        xmlns:behavior="clr-namespace:PL.Helpers.Behavior"
        WindowStartupLocation="CenterScreen"
        
         Loaded="Window_Loaded"
        >

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="ID:" Grid.Row="0" FontWeight="Bold"/>
            <TextBox Grid.Row="0" Grid.Column="1" Margin="5"
                     behavior:InputValidators.IsNumeric="True"
                     Text="{Binding CurrentCourier.Id, Mode=TwoWay}"
                     IsEnabled="{Binding IsAddMode}"/>

            <Label Content="Name:" Grid.Row="1" FontWeight="Bold"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="5"
                     Text="{Binding CurrentCourier.Name, Mode=TwoWay}"
                    behavior:InputValidators.IsLettersOnly="True"/>

            <Label Content="Email:" Grid.Row="2" FontWeight="Bold"/>
            <TextBox Grid.Row="2" Grid.Column="1" Margin="5"
                     Text="{Binding CurrentCourier.Email, Mode=TwoWay}"/>

            <Label Content="Phone:" Grid.Row="3" FontWeight="Bold"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="5"
                     Text="{Binding CurrentCourier.Phone, Mode=TwoWay}"
                     behavior:InputValidators.IsNumeric="True"/>

            <Label Content="Password:" Grid.Row="4" FontWeight="Bold"/>
            <TextBox Grid.Row="4" Grid.Column="1" Margin="5"
                     Text="{Binding CurrentCourier.Password, Mode=TwoWay}"/>

            <Label Content="Shipment Type:" Grid.Row="5" FontWeight="Bold"/>
            <ComboBox Grid.Row="5" Grid.Column="1" Margin="5,5,5,5"
                      ItemsSource="{Binding shipmentTypesList}"
                      SelectedValue="{Binding CurrentCourier.ShipmentType, Mode=TwoWay}"/>

            <Label Content="Max Dist (km):" Grid.Row="6" FontWeight="Bold"/>
            <TextBox Grid.Row="6" Grid.Column="1" Margin="5"
                     Text="{Binding CurrentCourier.MaxDistance, TargetNullValue='', Mode=TwoWay}"
                     behavior:InputValidators.IsNumeric="True"/>

            <Label Content="Is Active:" Grid.Row="7" FontWeight="Bold"/>
            <CheckBox Grid.Row="7" Grid.Column="1" Margin="5" VerticalAlignment="Center"
                      IsChecked="{Binding CurrentCourier.IsActive, Mode=TwoWay}"/>


            <Grid Grid.Row="9" Grid.ColumnSpan="2" Background="#F5F5F5" Margin="-10,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAddMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="2" Text="Performance &amp; Status" 
                           FontWeight="Bold" Foreground="Gray" Margin="10,5"/>

                <Label Grid.Row="1" Content="On Time:" Margin="10,0,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" 
                           Text="{Binding CurrentCourier.OrdersDeliveredInTime, Mode=OneWay}"/>

                <Label Grid.Row="2" Content="Late:" Margin="10,0,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" 
                           Text="{Binding CurrentCourier.OrdersDeliveredAfterTime, Mode=OneWay}"/>

                <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="10"/>

                <Label Grid.Row="4" Content="Current Order:" Margin="10,0,0,0" VerticalAlignment="Top" 
                      Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource StatusToVisibilityConverter}, FallbackValue=Visible}"/>
                
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,5"
                    Visibility="{Binding CurrentCourier.InProgress, Converter={StaticResource StatusToVisibilityConverter}}">
                    
                    <TextBlock Text="{Binding CurrentCourier.InProgress.OrderId, StringFormat='Order ID: {0}', TargetNullValue='None'}" FontWeight="SemiBold"/> 
                    <TextBlock Text="{Binding CurrentCourier.InProgress.OrderStatus, StringFormat='Status: {0}', TargetNullValue=''}" Foreground="Blue"/>
                    <TextBlock Text="{Binding CurrentCourier.InProgress.CustomerName, StringFormat='Client: {0}', TargetNullValue=''}" FontStyle="Italic"/>
                </StackPanel>
            </Grid>

            <Button Grid.Row="11" Grid.ColumnSpan="2" 
                    Content="{Binding ButtonContent}" 
                    Height="40" Width="150" 
                    HorizontalAlignment="Center"
                    Click="btnAddUpdate_Click"/>
        </Grid>
    </ScrollViewer>
</Window>